# ===== SMK-Android monorepo =====

# ---- Build outputs (root + every module under apps/ and core/) ----
build/
.gradle/
.kotlin/
/captures
.externalNativeBuild
.cxx

# ---- Local / machine-specific ----
local.properties
*.iml
.DS_Store

# ---- Python tooling caches (tools/) ----
__pycache__/
*.pyc

# ---- IDE (regenerated by Android Studio; un-ignore .idea/codeStyles etc. later if you want to share them) ----
.idea/

# ---- Secrets: NEVER commit signing material or keys ----
*.keystore
*.jks
keystore.properties
# …except the fixed DEBUG keystore. It uses the well-known standard debug credentials
# (android / androiddebugkey), so it is NOT a secret — the default Android debug key is globally
# shared. Committing it gives every debug build (local + each ephemeral CI runner) one stable
# signature, so the rolling "debug-latest" APK can update an existing install in place instead of
# forcing an uninstall that wipes the user's data. A real release keystore must NEVER be committed.
!apps/taskmind/debug.keystore

# ---- On-device LLM models (100s of MB to several GB; pushed to the device, not versioned) ----
*.task
*.litertlm

# ---- JVM crash artifacts (the Gradle test fork native-OOMs on a low-RAM host; never versioned) ----
hs_err_pid*.log
replay_pid*.log

# ---- Claude Code local config ----
.claude/

# ---- On-device QA scratch (screenshots / UI dumps / DataStore pulls) ----
_qa_*
_ds*.pb
