# Normalize line endings: LF in the repo for everything text, CRLF only for Windows scripts.
* text=auto eol=lf

# Windows batch/cmd scripts must stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix shell scripts stay LF (the Gradle wrapper)
gradlew text eol=lf
*.sh text eol=lf

# Binary assets — never touch
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.jar binary
*.keystore binary
*.jks binary
*.task binary
*.litertlm binary
