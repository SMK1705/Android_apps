<?xml version="1.0" encoding="utf-8"?>
<!--
   Legacy auto-backup rules (API < 31). The EncryptedSharedPreferences store and the SQLCipher
   database are protected by a device-bound Keystore key that is NOT backed up — restoring them onto
   a device with a different key makes them undecryptable and crashes the app at startup. Exclude
   them; intentional migration is handled by the in-app encrypted backup/restore.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="secret_shared_prefs.xml"/>
    <exclude domain="database" path="taskmind_db"/>
</full-backup-content>
