<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup / device-transfer rules (API 31+). The EncryptedSharedPreferences store and the SQLCipher
   database are protected by a device-bound Keystore key that is NOT transferred — restoring them
   onto a device with a different key makes them undecryptable and crashes the app at startup.
   Exclude them; intentional migration is handled by the in-app encrypted backup/restore.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secret_shared_prefs.xml"/>
        <exclude domain="database" path="taskmind_db"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secret_shared_prefs.xml"/>
        <exclude domain="database" path="taskmind_db"/>
    </device-transfer>
</data-extraction-rules>
